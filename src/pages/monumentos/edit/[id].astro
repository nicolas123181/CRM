---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import LanguageTabs from "../../../components/LanguageTabs.astro";
import { supabase } from "../../../lib/supabase";

const { id } = Astro.params;
let errorMessage = "";

const { data: monumento, error: fetchError } = await supabase
    .from("monumentos")
    .select("*")
    .eq("id", id)
    .single();

if (fetchError || !monumento) {
    return Astro.redirect("/monumentos");
}

if (Astro.request.method === "POST") {
    // Restaurar sesión de admin para poder hacer UPDATE
    const accessToken = Astro.cookies.get("sb-access-token")?.value;
    const refreshToken = Astro.cookies.get("sb-refresh-token")?.value;
    if (accessToken && refreshToken) {
        await supabase.auth.setSession({
            access_token: accessToken,
            refresh_token: refreshToken,
        });
    }

    const formData = await Astro.request.formData();
    const nombre = formData.get("nombre")?.toString();
    const descripcion = formData.get("descripcion")?.toString() || null;
    const imagen_url = formData.get("imagen_url")?.toString() || null;
    const audio_url = formData.get("audio_url")?.toString() || null;
    const audio_en = formData.get("audio_en")?.toString() || null;
    const audio_de = formData.get("audio_de")?.toString() || null;
    const audio_fr = formData.get("audio_fr")?.toString() || null;
    const latitud = formData.get("latitud")?.toString();
    const longitud = formData.get("longitud")?.toString();
    const orden = formData.get("orden")?.toString();
    const horario = formData.get("horario")?.toString() || null;

    // Multi-language fields
    const nombre_en = formData.get("nombre_en")?.toString() || null;
    const nombre_de = formData.get("nombre_de")?.toString() || null;
    const nombre_fr = formData.get("nombre_fr")?.toString() || null;
    const descripcion_en = formData.get("descripcion_en")?.toString() || null;
    const descripcion_de = formData.get("descripcion_de")?.toString() || null;
    const descripcion_fr = formData.get("descripcion_fr")?.toString() || null;
    const horario_en = formData.get("horario_en")?.toString() || null;
    const horario_de = formData.get("horario_de")?.toString() || null;
    const horario_fr = formData.get("horario_fr")?.toString() || null;

    if (nombre && latitud && longitud) {
        const { error } = await supabase
            .from("monumentos")
            .update({
                nombre,
                descripcion,
                imagen_url,
                audio_url,
                audio_en,
                audio_de,
                audio_fr,
                latitud: parseFloat(latitud),
                longitud: parseFloat(longitud),
                orden: orden ? parseInt(orden) : 0,
                horario,
                nombre_en,
                nombre_de,
                nombre_fr,
                descripcion_en,
                descripcion_de,
                descripcion_fr,
                horario_en,
                horario_de,
                horario_fr,
            })
            .eq("id", id);

        if (error) {
            errorMessage = error.message;
        } else {
            return Astro.redirect("/monumentos");
        }
    } else {
        errorMessage = "Por favor, completa los campos requeridos.";
    }
}

const mon = monumento;
