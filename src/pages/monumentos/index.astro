---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { supabase } from "../../lib/supabase";
import type { Monumento } from "../../types/database.types";

let actionError = "";

const url = new URL(Astro.request.url);
const searchName = url.searchParams.get("nombre") || "";
const sortBy = url.searchParams.get("ordenar") || "id"; // Default to ID

if (Astro.request.method === "POST") {
    // Autenticar la sesión para evitar que RLS bloquee la inserción/actualización
    const accessToken = Astro.cookies.get('sb-access-token')?.value;
    const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
    if (accessToken && refreshToken) {
        await supabase.auth.setSession({
            access_token: accessToken,
            refresh_token: refreshToken
        });
    }

    const formData = await Astro.request.formData();
    const action = formData.get("action");
    const monumentoId = formData.get("monumentoId");

    if (action === "delete" && monumentoId) {
        const { error: deleteError } = await supabase
            .from("monumentos")
            .delete()
            .eq("id", monumentoId);

        if (deleteError) {
            actionError = `Error al eliminar: ${deleteError.message}`;
        } else {
            return Astro.redirect("/monumentos");
        }
    }
}

let monumentos: Monumento[] = [];
let error = null;
let clickCountMap: Record<number, number> = {};

// Always get click counts for display
const { data: clickCounts } = await supabase
    .from("clicks_monumentos")
    .select("monumento_id");

// Count clicks per monument
clickCounts?.forEach((click: any) => {
    const id = click.monumento_id;
    clickCountMap[id] = (clickCountMap[id] || 0) + 1;
});

// Fetch monuments
let query = supabase.from("monumentos").select("*");
if (searchName) {
    query = query.ilike("nombre", `%${searchName}%`);
}
const { data, error: fetchError } = await query;
error = fetchError;

if (data) {
    if (sortBy === "visitas") {
        // Sort by click count descending
        monumentos = data.sort((a, b) => {
            const clicksA = clickCountMap[a.id] || 0;
            const clicksB = clickCountMap[b.id] || 0;
            return clicksB - clicksA;
        });
    } else {
        // Default: sort by ID ascending
        monumentos = data.sort((a, b) => a.id - b.id);
    }
}
---

<Layout title="Monumentos">
    <Navbar />

    <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
        <div class="animate-fade-in">
            <!-- Header -->
            <div class="sm:flex sm:items-center sm:justify-between mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-gray-900 tracking-tight">
                        Monumentos
                    </h1>
                    <p class="mt-2 text-lg text-gray-600">
                        Gestiona los monumentos y puntos de interés turístico.
                    </p>
                </div>
                <div class="mt-4 sm:mt-0">
                    <a
                        href="/monumentos/new"
                        class="inline-flex items-center px-5 py-2.5 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-amber-600 hover:bg-amber-700 transition-all hover:-translate-y-0.5"
                    >
                        <span class="mr-2 text-lg">➕</span>
                        Nuevo Monumento
                    </a>
                </div>
            </div>

            <!-- Search -->
            <div class="mb-6">
                <form method="GET" class="max-w-xl">
                    <div class="flex gap-2">
                        <div class="flex-1">
                            <label
                                for="nombre"
                                class="block text-sm font-medium text-gray-700 mb-1"
                                >Buscar por nombre</label
                            >
                            <input
                                type="text"
                                name="nombre"
                                id="nombre"
                                value={searchName}
                                placeholder="Nombre del monumento"
                                class="block w-full rounded-lg border-gray-300 shadow-sm focus:ring-amber-500 focus:border-amber-500 sm:text-sm"
                            />
                        </div>
                        <div class="flex items-end gap-2">
                            <button
                                type="submit"
                                class="px-4 py-2 text-sm font-medium rounded-lg text-white bg-amber-600 hover:bg-amber-700"
                            >
                                Buscar
                            </button>
                            {
                                searchName && (
                                    <a
                                        href="/monumentos"
                                        class="px-4 py-2 text-sm font-medium rounded-lg text-gray-700 bg-white border border-gray-300 hover:bg-gray-50"
                                    >
                                        Limpiar
                                    </a>
                                )
                            }
                        </div>
                    </div>
                </form>
            </div>

            <!-- Sort Options -->
            <div class="mb-6 flex items-center gap-4">
                <span class="text-sm font-medium text-gray-700"
                    >Ordenar por:</span
                >
                <div class="flex gap-2">
                    <a
                        href={`/monumentos?ordenar=id${searchName ? `&nombre=${searchName}` : ""}`}
                        class={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${
                            sortBy === "id"
                                ? "bg-amber-600 text-white shadow-sm"
                                : "bg-white text-gray-700 border border-gray-300 hover:bg-gray-50"
                        }`}
                    >
                        📋 Por ID
                    </a>
                    <a
                        href={`/monumentos?ordenar=visitas${searchName ? `&nombre=${searchName}` : ""}`}
                        class={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${
                            sortBy === "visitas"
                                ? "bg-amber-600 text-white shadow-sm"
                                : "bg-white text-gray-700 border border-gray-300 hover:bg-gray-50"
                        }`}
                    >
                        📊 Más visitados
                    </a>
                </div>
                {
                    monumentos && monumentos.length > 0 && (
                        <span class="text-sm text-gray-500 ml-auto">
                            {monumentos.length} monumento
                            {monumentos.length !== 1 ? "s" : ""}
                        </span>
                    )
                }
            </div>

            <!-- Grid -->
            <div class="mt-8">
                {
                    actionError && (
                        <div class="mb-6 bg-red-50 border-l-4 border-red-400 p-4 rounded-md">
                            <p class="text-sm text-red-700 font-medium">
                                {actionError}
                            </p>
                        </div>
                    )
                }

                {
                    error ? (
                        <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-md">
                            <p class="text-sm text-red-700">
                                Error: {error.message}
                            </p>
                        </div>
                    ) : monumentos && monumentos.length > 0 ? (
                        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                            {(monumentos as Monumento[]).map((mon, index) => (
                                <div
                                    class="bg-white rounded-xl shadow-sm ring-1 ring-gray-900/5 hover:shadow-md hover:ring-amber-500/30 transition-all duration-300 group animate-slide-up overflow-hidden"
                                    style={`animation-delay: ${index * 50}ms;`}
                                >
                                    {mon.imagen_url ? (
                                        <div class="h-44 overflow-hidden">
                                            <img
                                                src={mon.imagen_url}
                                                alt={mon.nombre}
                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                            />
                                        </div>
                                    ) : (
                                        <div class="h-44 bg-gradient-to-br from-amber-100 to-amber-200 flex items-center justify-center">
                                            <span class="text-6xl">🏛️</span>
                                        </div>
                                    )}

                                    <div class="p-5">
                                        <div class="flex items-start justify-between">
                                            <div class="flex-1">
                                                <div class="flex items-center gap-2 mb-1">
                                                    <span class="inline-flex items-center justify-center px-2 py-0.5 rounded bg-gray-100 text-gray-600 text-xs font-medium">
                                                        ID: {mon.id}
                                                    </span>
                                                    {mon.audio_url && (
                                                        <span
                                                            class="text-purple-600"
                                                            title="Audio ES"
                                                        >
                                                            🔊ES
                                                        </span>
                                                    )}
                                                    {mon.audio_en && (
                                                        <span
                                                            class="text-blue-600"
                                                            title="Audio EN"
                                                        >
                                                            🔊EN
                                                        </span>
                                                    )}
                                                    {mon.audio_de && (
                                                        <span
                                                            class="text-yellow-600"
                                                            title="Audio DE"
                                                        >
                                                            🔊DE
                                                        </span>
                                                    )}
                                                    {mon.audio_fr && (
                                                        <span
                                                            class="text-red-600"
                                                            title="Audio FR"
                                                        >
                                                            🔊FR
                                                        </span>
                                                    )}
                                                    {clickCountMap[mon.id] >
                                                        0 && (
                                                        <span
                                                            class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-green-100 text-green-700 text-xs font-medium"
                                                            title="Total de visitas"
                                                        >
                                                            👁️{" "}
                                                            {clickCountMap[
                                                                mon.id
                                                            ].toLocaleString()}
                                                        </span>
                                                    )}
                                                </div>
                                                <h3 class="text-lg font-semibold text-gray-900 group-hover:text-amber-600 transition-colors">
                                                    {mon.nombre}
                                                </h3>
                                            </div>
                                        </div>

                                        {mon.descripcion && (
                                            <p class="text-sm text-gray-500 mt-2 line-clamp-2">
                                                {mon.descripcion}
                                            </p>
                                        )}

                                        {mon.horario && (
                                            <div class="mt-2 flex items-center text-sm text-gray-600">
                                                <span class="mr-1">🕐</span>{" "}
                                                {mon.horario}
                                            </div>
                                        )}

                                        <div class="mt-3 flex items-center text-sm text-gray-600">
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                fill="none"
                                                viewBox="0 0 24 24"
                                                stroke-width="1.5"
                                                stroke="currentColor"
                                                class="w-4 h-4 mr-2 text-gray-400"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"
                                                />
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                                                />
                                            </svg>
                                            <a
                                                href={`https://www.google.com/maps?q=${mon.latitud},${mon.longitud}`}
                                                target="_blank"
                                                class="hover:text-amber-600 hover:underline"
                                            >
                                                Ver en Maps
                                            </a>
                                        </div>

                                        <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between text-xs text-gray-500">
                                            <a
                                                href={`/monumentos/${mon.id}`}
                                                class="text-amber-600 hover:text-amber-800 font-medium"
                                            >
                                                📊 Ver estadísticas
                                            </a>
                                            <div class="flex space-x-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                                <a
                                                    href={`/monumentos/edit/${mon.id}`}
                                                    class="text-blue-600 hover:text-blue-800 font-medium"
                                                >
                                                    Editar
                                                </a>
                                                <span class="text-gray-300">
                                                    |
                                                </span>
                                                <form
                                                    method="POST"
                                                    class="inline"
                                                    onsubmit="return confirm('¿Eliminar este monumento?')"
                                                >
                                                    <input
                                                        type="hidden"
                                                        name="action"
                                                        value="delete"
                                                    />
                                                    <input
                                                        type="hidden"
                                                        name="monumentoId"
                                                        value={mon.id}
                                                    />
                                                    <button
                                                        type="submit"
                                                        class="text-red-600 hover:text-red-800 font-medium"
                                                    >
                                                        Eliminar
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    ) : (
                        <div class="text-center py-20 bg-white rounded-2xl shadow-sm ring-1 ring-gray-900/5">
                            <div class="text-6xl mb-4">🏛️</div>
                            <h3 class="text-lg font-medium text-gray-900">
                                No hay monumentos registrados
                            </h3>
                            <p class="mt-1 text-sm text-gray-500">
                                Comienza agregando tu primer monumento.
                            </p>
                            <div class="mt-6">
                                <a
                                    href="/monumentos/new"
                                    class="inline-flex items-center px-4 py-2 text-sm font-medium rounded-md text-white bg-amber-600 hover:bg-amber-700"
                                >
                                    <span class="mr-2">➕</span> Nuevo Monumento
                                </a>
                            </div>
                        </div>
                    )
                }
            </div>
        </div>
    </main>
</Layout>
