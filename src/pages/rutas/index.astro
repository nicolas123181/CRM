---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { supabase } from "../../lib/supabase";

const profile = Astro.locals.profile;
const isAdmin = profile.role === "admin";

// Fetch all rutas oficiales
const { data: rutas, error } = await supabase
    .from("rutas_oficiales")
    .select("*")
    .order("id", { ascending: true });

// Fetch monuments to show names
const { data: monumentos } = await supabase
    .from("monumentos")
    .select("id, nombre, imagen_url");

// Create a map for quick monument lookup
const monumentoMap = new Map(monumentos?.map((m) => [m.id, m]) || []);

// Handle delete action
if (Astro.request.method === "POST" && isAdmin) {
    const formData = await Astro.request.formData();
    const action = formData.get("action");
    const rutaId = formData.get("rutaId");

    if (action === "delete" && rutaId) {
        await supabase.from("rutas_oficiales").delete().eq("id", rutaId);
        return Astro.redirect("/rutas");
    }
}

const getDificultadColor = (dificultad: string | null) => {
    switch (dificultad?.toLowerCase()) {
        case "fácil":
        case "facil":
            return "bg-green-100 text-green-800";
        case "media":
        case "moderada":
            return "bg-yellow-100 text-yellow-800";
        case "difícil":
        case "dificil":
            return "bg-red-100 text-red-800";
        default:
            return "bg-gray-100 text-gray-800";
    }
};
---

<Layout title="Rutas Históricas">
    <Navbar />

    <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
        <div class="animate-fade-in">
            <!-- Header -->
            <div class="sm:flex sm:items-center sm:justify-between mb-8">
                <div>
                    <h1
                        class="text-3xl font-bold text-gray-900 tracking-tight flex items-center gap-3"
                    >
                        <span class="text-4xl">🗺️</span>
                        Rutas Históricas
                    </h1>
                    <p class="mt-2 text-lg text-gray-600">
                        Gestiona las rutas oficiales prediseñadas de la
                        aplicación.
                    </p>
                </div>
                {
                    isAdmin && (
                        <div class="mt-4 sm:mt-0">
                            <a
                                href="/rutas/new"
                                class="inline-flex items-center px-5 py-2.5 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-all hover:-translate-y-0.5"
                            >
                                <span class="mr-2 text-lg">➕</span>
                                Nueva Ruta
                            </a>
                        </div>
                    )
                }
            </div>

            <!-- Routes Grid/Table -->
            <div
                class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-xl overflow-hidden"
            >
                {
                    error ? (
                        <div class="p-6">
                            <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-md">
                                <p class="text-sm text-red-700">
                                    Error al cargar rutas: {error.message}
                                </p>
                            </div>
                        </div>
                    ) : rutas && rutas.length > 0 ? (
                        <div class="overflow-x-auto">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th
                                            scope="col"
                                            class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                                        >
                                            ID
                                        </th>
                                        <th
                                            scope="col"
                                            class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                                        >
                                            Ruta
                                        </th>
                                        <th
                                            scope="col"
                                            class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                                        >
                                            Monumentos
                                        </th>
                                        <th
                                            scope="col"
                                            class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                                        >
                                            Duración
                                        </th>
                                        <th
                                            scope="col"
                                            class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                                        >
                                            Dificultad
                                        </th>
                                        {isAdmin && (
                                            <th
                                                scope="col"
                                                class="relative px-6 py-3"
                                            >
                                                <span class="sr-only">
                                                    Acciones
                                                </span>
                                            </th>
                                        )}
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y divide-gray-200">
                                    {rutas.map((ruta: any) => {
                                        // Ensure orden_monumentos is an array - handle JSONB properly
                                        let monumentoIds: number[] = [];
                                        const rawOrden = ruta.orden_monumentos;
                                        if (Array.isArray(rawOrden)) {
                                            monumentoIds = rawOrden;
                                        } else if (
                                            typeof rawOrden === "string"
                                        ) {
                                            try {
                                                const parsed =
                                                    JSON.parse(rawOrden);
                                                monumentoIds = Array.isArray(
                                                    parsed,
                                                )
                                                    ? parsed
                                                    : [];
                                            } catch {
                                                monumentoIds = [];
                                            }
                                        } else if (
                                            rawOrden &&
                                            typeof rawOrden === "object"
                                        ) {
                                            monumentoIds =
                                                Object.values(rawOrden);
                                        }
                                        const monumentosList = monumentoIds
                                            .map((id: number) =>
                                                monumentoMap.get(id),
                                            )
                                            .filter(Boolean);

                                        return (
                                            <tr class="hover:bg-gray-50 transition-colors">
                                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                                    #{ruta.id}
                                                </td>
                                                <td class="px-6 py-4">
                                                    <div class="flex flex-col">
                                                        <span class="text-sm font-semibold text-gray-900">
                                                            {ruta.nombre}
                                                        </span>
                                                        {ruta.descripcion && (
                                                            <span class="text-xs text-gray-500 truncate max-w-xs">
                                                                {ruta.descripcion.substring(
                                                                    0,
                                                                    80,
                                                                )}
                                                                ...
                                                            </span>
                                                        )}
                                                    </div>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <div class="flex flex-wrap gap-1">
                                                        {monumentosList.length >
                                                        0 ? (
                                                            <>
                                                                {monumentosList
                                                                    .slice(0, 3)
                                                                    .map(
                                                                        (
                                                                            m: any,
                                                                            idx: number,
                                                                        ) => (
                                                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs bg-indigo-100 text-indigo-800">
                                                                                {idx +
                                                                                    1}

                                                                                .{" "}
                                                                                {m.nombre.substring(
                                                                                    0,
                                                                                    15,
                                                                                )}
                                                                                {m
                                                                                    .nombre
                                                                                    .length >
                                                                                15
                                                                                    ? "..."
                                                                                    : ""}
                                                                            </span>
                                                                        ),
                                                                    )}
                                                                {monumentosList.length >
                                                                    3 && (
                                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs bg-gray-100 text-gray-600">
                                                                        +
                                                                        {monumentosList.length -
                                                                            3}{" "}
                                                                        más
                                                                    </span>
                                                                )}
                                                            </>
                                                        ) : (
                                                            <span class="text-xs text-gray-400 italic">
                                                                Sin monumentos
                                                            </span>
                                                        )}
                                                    </div>
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                    {ruta.duracion_min ? (
                                                        <span class="flex items-center gap-1">
                                                            ⏱️{" "}
                                                            {ruta.duracion_min}{" "}
                                                            min
                                                        </span>
                                                    ) : (
                                                        <span class="text-gray-400">
                                                            —
                                                        </span>
                                                    )}
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap">
                                                    {ruta.dificultad ? (
                                                        <span
                                                            class={`px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${getDificultadColor(ruta.dificultad)}`}
                                                        >
                                                            {ruta.dificultad}
                                                        </span>
                                                    ) : (
                                                        <span class="text-gray-400 text-sm">
                                                            —
                                                        </span>
                                                    )}
                                                </td>
                                                {isAdmin && (
                                                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                                        <div class="flex justify-end space-x-3">
                                                            <a
                                                                href={`/rutas/edit/${ruta.id}`}
                                                                class="text-primary-600 hover:text-primary-900"
                                                            >
                                                                Editar
                                                            </a>
                                                            <form
                                                                method="POST"
                                                                class="inline"
                                                                onsubmit="return confirm('¿Estás seguro de que deseas eliminar esta ruta?')"
                                                            >
                                                                <input
                                                                    type="hidden"
                                                                    name="action"
                                                                    value="delete"
                                                                />
                                                                <input
                                                                    type="hidden"
                                                                    name="rutaId"
                                                                    value={
                                                                        ruta.id
                                                                    }
                                                                />
                                                                <button
                                                                    type="submit"
                                                                    class="text-red-600 hover:text-red-900"
                                                                >
                                                                    Eliminar
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </td>
                                                )}
                                            </tr>
                                        );
                                    })}
                                </tbody>
                            </table>
                        </div>
                    ) : (
                        <div class="text-center py-20">
                            <span class="text-6xl block mb-4">🗺️</span>
                            <h3 class="text-lg font-medium text-gray-900">
                                No hay rutas históricas
                            </h3>
                            <p class="mt-1 text-sm text-gray-500">
                                Comienza creando tu primera ruta oficial.
                            </p>
                            {isAdmin && (
                                <div class="mt-6">
                                    <a
                                        href="/rutas/new"
                                        class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700"
                                    >
                                        <span class="mr-2">➕</span>
                                        Nueva Ruta
                                    </a>
                                </div>
                            )}
                        </div>
                    )
                }
            </div>
        </div>
    </main>
</Layout>
