---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { supabase } from "../../lib/supabase";

const profile = Astro.locals.profile;
if (!profile) {
    return Astro.redirect("/login");
}
if (profile.role !== "admin") {
    return Astro.redirect("/cultural");
}

let errorMessage = "";

if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const titulo = formData.get("titulo")?.toString();
    const descripcion = formData.get("descripcion")?.toString() || null;
    const fecha = formData.get("fecha")?.toString();
    const hora = formData.get("hora")?.toString() || "12:00";

    if (titulo && fecha) {
        // Combine date and time
        const fechaCompleta = `${fecha}T${hora}:00`;

        const { error } = await supabase.from("eventos").insert({
            titulo,
            descripcion,
            fecha: fechaCompleta,
            cultural: 1, // Always set to 1 for cultural events
        });

        if (error) {
            errorMessage = error.message;
        } else {
            return Astro.redirect("/cultural");
        }
    } else {
        errorMessage = "El título y la fecha son obligatorios.";
    }
}

// Get current date for default value
const today = new Date().toISOString().split("T")[0];
---

<Layout title="Nuevo Evento Cultural">
    <Navbar />

    <main class="max-w-2xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
        <div class="animate-fade-in">
            <!-- Breadcrumb -->
            <nav class="flex mb-8" aria-label="Breadcrumb">
                <ol role="list" class="flex items-center space-x-4">
                    <li>
                        <a
                            href="/cultural"
                            class="text-gray-400 hover:text-gray-500"
                        >
                            <svg
                                class="h-5 w-5"
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 20 20"
                                fill="currentColor"
                            >
                                <path
                                    d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"
                                ></path>
                            </svg>
                        </a>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <svg
                                class="h-5 w-5 text-gray-300"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z"
                                ></path>
                            </svg>
                            <a
                                href="/cultural"
                                class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700"
                            >
                                Programación Cultural
                            </a>
                        </div>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <svg
                                class="h-5 w-5 text-gray-300"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z"
                                ></path>
                            </svg>
                            <span class="ml-4 text-sm font-medium text-gray-500"
                                >Nuevo Evento</span
                            >
                        </div>
                    </li>
                </ol>
            </nav>

            <div
                class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-xl overflow-hidden"
            >
                <div
                    class="px-6 py-5 text-white"
                    style="background: linear-gradient(to right, #a855f7, #ec4899);"
                >
                    <h3
                        class="text-lg leading-6 font-medium flex items-center gap-2"
                    >
                        <span class="text-xl">🎭</span>
                        Nuevo Evento Cultural
                    </h3>
                    <p
                        class="mt-1 text-sm"
                        style="color: rgba(255,255,255,0.8);"
                    >
                        Añade un nuevo evento a la programación cultural.
                    </p>
                </div>

                <form method="POST" class="p-6 space-y-6">
                    {
                        errorMessage && (
                            <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-md">
                                <p class="text-sm text-red-700">
                                    {errorMessage}
                                </p>
                            </div>
                        )
                    }

                    <div>
                        <label
                            for="titulo"
                            class="block text-sm font-medium text-gray-700 mb-1"
                        >
                            Título del Evento <span class="text-red-500">*</span
                            >
                        </label>
                        <input
                            type="text"
                            name="titulo"
                            id="titulo"
                            required
                            placeholder="Ej: Concierto de Navidad"
                            class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>

                    <div>
                        <label
                            for="descripcion"
                            class="block text-sm font-medium text-gray-700 mb-1"
                        >
                            Descripción
                        </label>
                        <textarea
                            name="descripcion"
                            id="descripcion"
                            rows="4"
                            placeholder="Describe el evento..."
                            class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-primary-500 focus:border-primary-500"
                        ></textarea>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label
                                for="fecha"
                                class="block text-sm font-medium text-gray-700 mb-1"
                            >
                                Fecha <span class="text-red-500">*</span>
                            </label>
                            <input
                                type="date"
                                name="fecha"
                                id="fecha"
                                required
                                min={today}
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-primary-500 focus:border-primary-500"
                            />
                        </div>
                        <div>
                            <label
                                for="hora"
                                class="block text-sm font-medium text-gray-700 mb-1"
                            >
                                Hora
                            </label>
                            <input
                                type="time"
                                name="hora"
                                id="hora"
                                value="20:00"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-primary-500 focus:border-primary-500"
                            />
                        </div>
                    </div>

                    <!-- Hidden field to mark as cultural -->
                    <input type="hidden" name="cultural" value="1" />

                    <div
                        class="pt-5 border-t border-gray-100 flex justify-end gap-3"
                    >
                        <a
                            href="/cultural"
                            class="px-4 py-2 border border-gray-300 rounded-lg shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50"
                        >
                            Cancelar
                        </a>
                        <button
                            type="submit"
                            class="px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 transition-all hover:-translate-y-0.5"
                        >
                            Crear Evento
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</Layout>
