---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { supabase } from "../../lib/supabase";

const profile = Astro.locals.profile;
if (!profile) {
    return Astro.redirect("/login");
}
const isAdmin = profile.role === "admin";

// Handle delete action
if (Astro.request.method === "POST" && isAdmin) {
    const formData = await Astro.request.formData();
    const action = formData.get("action");
    const eventoId = formData.get("eventoId");

    if (action === "delete" && eventoId) {
        await supabase.from("eventos").delete().eq("id", eventoId);
        return Astro.redirect("/cultural");
    }
}

// Fetch only cultural events (cultural = 1)
const { data: eventos, error } = await supabase
    .from("eventos")
    .select("*")
    .eq("cultural", 1)
    .order("fecha", { ascending: true });

// Group events by month
const eventsByMonth: Record<string, any[]> = {};
eventos?.forEach((evento) => {
    const date = new Date(evento.fecha);
    const monthKey = date.toLocaleDateString("es-ES", { year: "numeric", month: "long" });
    if (!eventsByMonth[monthKey]) {
        eventsByMonth[monthKey] = [];
    }
    eventsByMonth[monthKey].push(evento);
});

const formatDate = (dateStr: string) => {
    const date = new Date(dateStr);
    return {
        day: date.getDate(),
        weekday: date.toLocaleDateString("es-ES", { weekday: "short" }),
        month: date.toLocaleDateString("es-ES", { month: "short" }),
        time: date.toLocaleTimeString("es-ES", { hour: "2-digit", minute: "2-digit" }),
        full: date.toLocaleDateString("es-ES", { weekday: "long", day: "numeric", month: "long", year: "numeric" })
    };
};
---

<Layout title="Programación Cultural">
    <Navbar />

    <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
        <div class="animate-fade-in">
            <!-- Header -->
            <div class="sm:flex sm:items-center sm:justify-between mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-gray-900 tracking-tight flex items-center gap-3">
                        <span class="text-4xl">🎭</span>
                        Programación Cultural
                    </h1>
                    <p class="mt-2 text-lg text-gray-600">
                        Gestiona los eventos culturales de la aplicación.
                    </p>
                </div>
                {isAdmin && (
                    <div class="mt-4 sm:mt-0">
                        <a
                            href="/cultural/new"
                            class="inline-flex items-center px-5 py-2.5 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-all hover:-translate-y-0.5"
                        >
                            <span class="mr-2 text-lg">➕</span>
                            Nuevo Evento
                        </a>
                    </div>
                )}
            </div>

            <!-- Events List -->
            <div class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-xl overflow-hidden">
                {error ? (
                    <div class="p-6">
                        <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-md">
                            <p class="text-sm text-red-700">
                                Error al cargar eventos: {error.message}
                            </p>
                        </div>
                    </div>
                ) : eventos && eventos.length > 0 ? (
                    <div class="divide-y divide-gray-100">
                        {Object.entries(eventsByMonth).map(([month, monthEvents]) => (
                            <div>
                                <div class="px-6 py-3 bg-gradient-to-r from-purple-50 to-pink-50 border-b border-purple-100">
                                    <h2 class="text-sm font-semibold text-purple-800 uppercase tracking-wider">
                                        📅 {month}
                                    </h2>
                                </div>
                                <div class="divide-y divide-gray-50">
                                    {monthEvents.map((evento: any) => {
                                        const date = formatDate(evento.fecha);
                                        return (
                                            <div class="flex items-start gap-4 p-4 hover:bg-gray-50 transition-colors">
                                                <!-- Date Badge -->
                                                <div class="flex-shrink-0 w-16 text-center">
                                                    <div class="bg-purple-600 text-white rounded-t-lg py-1 text-xs font-medium uppercase">
                                                        {date.weekday}
                                                    </div>
                                                    <div class="bg-white border-2 border-purple-600 border-t-0 rounded-b-lg py-2">
                                                        <span class="text-2xl font-bold text-gray-900">{date.day}</span>
                                                        <div class="text-xs text-gray-500 uppercase">{date.month}</div>
                                                    </div>
                                                </div>
                                                
                                                <!-- Event Info -->
                                                <div class="flex-1 min-w-0">
                                                    <h3 class="text-lg font-semibold text-gray-900">
                                                        {evento.titulo}
                                                    </h3>
                                                    {evento.descripcion && (
                                                        <p class="mt-1 text-sm text-gray-600 line-clamp-2">
                                                            {evento.descripcion}
                                                        </p>
                                                    )}
                                                    <div class="mt-2 flex items-center gap-4 text-sm text-gray-500">
                                                        <span class="flex items-center gap-1">
                                                            🕐 {date.time}
                                                        </span>
                                                    </div>
                                                </div>
                                                
                                                <!-- Actions -->
                                                {isAdmin && (
                                                    <div class="flex-shrink-0 flex items-center gap-2">
                                                        <a
                                                            href={`/cultural/edit/${evento.id}`}
                                                            class="p-2 text-gray-400 hover:text-purple-600 hover:bg-purple-50 rounded-lg transition-colors"
                                                            title="Editar"
                                                        >
                                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                                            </svg>
                                                        </a>
                                                        <form
                                                            method="POST"
                                                            class="inline"
                                                            onsubmit="return confirm('¿Eliminar este evento?')"
                                                        >
                                                            <input type="hidden" name="action" value="delete" />
                                                            <input type="hidden" name="eventoId" value={evento.id} />
                                                            <button
                                                                type="submit"
                                                                class="p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors"
                                                                title="Eliminar"
                                                            >
                                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                                                </svg>
                                                            </button>
                                                        </form>
                                                    </div>
                                                )}
                                            </div>
                                        );
                                    })}
                                </div>
                            </div>
                        ))}
                    </div>
                ) : (
                    <div class="text-center py-20">
                        <span class="text-6xl block mb-4">🎭</span>
                        <h3 class="text-lg font-medium text-gray-900">
                            No hay eventos culturales
                        </h3>
                        <p class="mt-1 text-sm text-gray-500">
                            Comienza añadiendo el primer evento cultural.
                        </p>
                        {isAdmin && (
                            <div class="mt-6">
                                <a
                                    href="/cultural/new"
                                    class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700"
                                >
                                    <span class="mr-2">➕</span>
                                    Nuevo Evento
                                </a>
                            </div>
                        )}
                    </div>
                )}
            </div>
        </div>
    </main>
</Layout>
