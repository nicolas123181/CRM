---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import LanguageTabs from "../../components/LanguageTabs.astro";
import { supabase } from "../../lib/supabase";
import { uploadToCloudinary } from "../../lib/cloudinary";

const profile = Astro.locals.profile;
if (!profile) {
    return Astro.redirect("/login");
}
if (profile.role !== "admin") {
    return Astro.redirect("/personajes");
}

let errorMessage = "";

if (Astro.request.method === "POST") {
    const accessToken = Astro.cookies.get("sb-access-token")?.value;
    const refreshToken = Astro.cookies.get("sb-refresh-token")?.value;
    if (accessToken && refreshToken) {
        await supabase.auth.setSession({
            access_token: accessToken,
            refresh_token: refreshToken,
        });
    }

    const formData = await Astro.request.formData();
    const name = formData.get("name")?.toString();
    const descripcion = formData.get("descripcion")?.toString() || null;
    const imagenFile = formData.get("imagen") as File | null;

    const audioFile = formData.get("audio") as File | null;
    const audioFileEn = formData.get("audio_en") as File | null;
    const audioFileDe = formData.get("audio_de") as File | null;
    const audioFileFr = formData.get("audio_fr") as File | null;

    const name_en = formData.get("name_en")?.toString() || null;
    const name_de = formData.get("name_de")?.toString() || null;
    const name_fr = formData.get("name_fr")?.toString() || null;
    const descripcion_en = formData.get("descripcion_en")?.toString() || null;
    const descripcion_de = formData.get("descripcion_de")?.toString() || null;
    const descripcion_fr = formData.get("descripcion_fr")?.toString() || null;

    if (name) {
        let imagen_url: string | null = null;
        let audio_url: string | null = null;
        let audio_url_en: string | null = null;
        let audio_url_de: string | null = null;
        let audio_url_fr: string | null = null;

        if (imagenFile && imagenFile.size > 0) {
            try {
                imagen_url = await uploadToCloudinary(
                    imagenFile,
                    "PersonajesIlustres",
                );
            } catch (e: any) {
                errorMessage = `Error al subir imagen: ${e.message}`;
            }
        }

        if (!errorMessage) {
            try {
                if (audioFile && audioFile.size > 0)
                    audio_url = await uploadToCloudinary(
                        audioFile,
                        "PersonajesIlustres",
                    );
                if (audioFileEn && audioFileEn.size > 0)
                    audio_url_en = await uploadToCloudinary(
                        audioFileEn,
                        "PersonajesIlustres",
                    );
                if (audioFileDe && audioFileDe.size > 0)
                    audio_url_de = await uploadToCloudinary(
                        audioFileDe,
                        "PersonajesIlustres",
                    );
                if (audioFileFr && audioFileFr.size > 0)
                    audio_url_fr = await uploadToCloudinary(
                        audioFileFr,
                        "PersonajesIlustres",
                    );
            } catch (e: any) {
                errorMessage = e.message;
            }
        }

        if (!errorMessage) {
            const { error } = await supabase.from("personajes").insert({
                name,
                descripcion,
                imagen_url,
                audio_url,
                name_en,
                name_de,
                name_fr,
                descripcion_en,
                descripcion_de,
                descripcion_fr,
                audio_url_en,
                audio_url_de,
                audio_url_fr,
            });

            if (error) {
                errorMessage = error.message;
            } else {
                return Astro.redirect("/personajes");
            }
        }
    } else {
        errorMessage = "El nombre es obligatorio.";
    }
}
---

<Layout title="Nuevo Personaje Ilustre">
    <Navbar />

    <main class="max-w-2xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
        <div class="animate-fade-in">
            <nav class="flex mb-8" aria-label="Breadcrumb">
                <ol role="list" class="flex items-center space-x-4">
                    <li>
                        <a
                            href="/personajes"
                            class="text-gray-400 hover:text-gray-500"
                        >
                            <svg
                                class="h-5 w-5"
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 20 20"
                                fill="currentColor"
                            >
                                <path
                                    d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"
                                ></path>
                            </svg>
                        </a>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <svg
                                class="h-5 w-5 text-gray-300"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z"
                                ></path>
                            </svg>
                            <a
                                href="/personajes"
                                class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700"
                                >Personajes Ilustres</a
                            >
                        </div>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <svg
                                class="h-5 w-5 text-gray-300"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z"
                                ></path>
                            </svg>
                            <span class="ml-4 text-sm font-medium text-gray-500"
                                >Nuevo</span
                            >
                        </div>
                    </li>
                </ol>
            </nav>

            <div
                class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-xl overflow-hidden"
            >
                <div
                    class="px-6 py-5 text-white"
                    style="background: linear-gradient(to right, #6366f1, #8b5cf6);"
                >
                    <h3
                        class="text-lg leading-6 font-medium flex items-center gap-2"
                    >
                        <span class="text-xl">👤</span>
                        Nuevo Personaje Ilustre
                    </h3>
                    <p
                        class="mt-1 text-sm"
                        style="color: rgba(255,255,255,0.8);"
                    >
                        Añade un nuevo personaje histórico de Sanlúcar.
                    </p>
                </div>

                <form
                    method="POST"
                    enctype="multipart/form-data"
                    class="p-6 space-y-6"
                >
                    {
                        errorMessage && (
                            <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-md">
                                <p class="text-sm text-red-700">
                                    {errorMessage}
                                </p>
                            </div>
                        )
                    }

                    <div class="mb-6">
                        <h4
                            class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-4 flex items-center gap-2"
                        >
                            🌐 Información Básica y Traducciones
                        </h4>
                        <LanguageTabs
                            prefix="personajes"
                            fields={[
                                {
                                    name: "name",
                                    label: "Nombre",
                                    type: "input",
                                    placeholder: "Ej: Fernando de Magallanes",
                                    required: true,
                                },
                                {
                                    name: "descripcion",
                                    label: "Descripción",
                                    type: "textarea",
                                    placeholder: "Describe al personaje...",
                                    rows: 4,
                                },
                            ]}
                            values={{}}
                        />
                    </div>

                    <div class="mb-6">
                        <h4
                            class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-4"
                        >
                            📷 Imagen
                        </h4>
                        <div
                            class="flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-lg hover:border-indigo-400 transition-colors"
                        >
                            <div class="space-y-1 text-center">
                                <svg
                                    class="mx-auto h-12 w-12 text-gray-400"
                                    stroke="currentColor"
                                    fill="none"
                                    viewBox="0 0 48 48"
                                >
                                    <path
                                        d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"></path>
                                </svg>
                                <div class="flex text-sm text-gray-600">
                                    <label
                                        for="imagen"
                                        class="relative cursor-pointer bg-white rounded-md font-medium text-indigo-600 hover:text-indigo-500"
                                    >
                                        <span>Subir imagen</span>
                                        <input
                                            id="imagen"
                                            name="imagen"
                                            type="file"
                                            accept="image/*"
                                            class="sr-only"
                                        />
                                    </label>
                                </div>
                                <p class="text-xs text-gray-500">
                                    PNG, JPG, WEBP hasta 10MB
                                </p>
                            </div>
                        </div>
                        <div id="imagenPreview" class="mt-3 hidden">
                            <p class="text-sm text-gray-600 mb-2">
                                Vista previa:
                            </p>
                            <img
                                id="imagenPlayer"
                                class="h-32 w-auto rounded-lg object-cover"
                            />
                        </div>
                    </div>

                    <div class="mb-6">
                        <h4
                            class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-4"
                        >
                            🔊 Audioguías por Idioma
                        </h4>

                        <div class="mb-4 p-4 border border-gray-200 rounded-lg">
                            <label
                                class="block text-sm font-medium text-gray-700 mb-2"
                                >🇪🇸 Audio Español</label
                            >
                            <input
                                type="file"
                                name="audio"
                                accept="audio/*"
                                class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100"
                            />
                        </div>

                        <div class="mb-4 p-4 border border-gray-200 rounded-lg">
                            <label
                                class="block text-sm font-medium text-gray-700 mb-2"
                                >🇬🇧 Audio English</label
                            >
                            <input
                                type="file"
                                name="audio_en"
                                accept="audio/*"
                                class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
                            />
                        </div>

                        <div class="mb-4 p-4 border border-gray-200 rounded-lg">
                            <label
                                class="block text-sm font-medium text-gray-700 mb-2"
                                >🇩🇪 Audio Deutsch</label
                            >
                            <input
                                type="file"
                                name="audio_de"
                                accept="audio/*"
                                class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-yellow-50 file:text-yellow-700 hover:file:bg-yellow-100"
                            />
                        </div>

                        <div class="mb-4 p-4 border border-gray-200 rounded-lg">
                            <label
                                class="block text-sm font-medium text-gray-700 mb-2"
                                >🇫🇷 Audio Français</label
                            >
                            <input
                                type="file"
                                name="audio_fr"
                                accept="audio/*"
                                class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-purple-50 file:text-purple-700 hover:file:bg-purple-100"
                            />
                        </div>
                    </div>

                    <div
                        class="pt-5 border-t border-gray-100 flex justify-end gap-3"
                    >
                        <a
                            href="/personajes"
                            class="px-4 py-2 border border-gray-300 rounded-lg shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50"
                        >
                            Cancelar
                        </a>
                        <button
                            type="submit"
                            class="px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 transition-all hover:-translate-y-0.5"
                        >
                            Crear Personaje
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <script is:inline>
        document
            .getElementById("imagen")
            .addEventListener("change", function (e) {
                const file = e.target.files[0];
                if (file) {
                    const preview = document.getElementById("imagenPreview");
                    const img = document.getElementById("imagenPlayer");
                    img.src = URL.createObjectURL(file);
                    preview.classList.remove("hidden");
                }
            });
    </script>
</Layout>
