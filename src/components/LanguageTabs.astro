---
/**
 * LanguageTabs Component
 *
 * A reusable component for multi-language input fields with flag-based tabs.
 *
 * Props:
 * - fields: Array of field configurations
 * - values: Object with current values for edit forms
 * - prefix: Unique prefix for this instance (for multiple language sections)
 */

interface Field {
    name: string; // Base field name (e.g., "nombre", "descripcion")
    label: string; // Spanish label
    type: "input" | "textarea";
    placeholder?: string;
    rows?: number; // For textarea
    required?: boolean; // If Spanish field is required
}

interface Props {
    fields: Field[];
    values?: Record<string, string | null>;
    prefix?: string;
}

const { fields, values = {}, prefix = "lang" } = Astro.props;

const languages = [
    { code: "es", flag: "🇪🇸", name: "Español" },
    { code: "en", flag: "🇬🇧", name: "English" },
    { code: "de", flag: "🇩🇪", name: "Deutsch" },
    { code: "fr", flag: "🇫🇷", name: "Français" },
];

// Helper to get field name with language suffix
function getFieldName(baseName: string, langCode: string): string {
    if (langCode === "es") return baseName;
    return `${baseName}_${langCode}`;
}

// Helper to get value
function getValue(baseName: string, langCode: string): string {
    const fieldName = getFieldName(baseName, langCode);
    return values[fieldName] || "";
}
---

<div class={`lang-tabs-container ${prefix}`} data-prefix={prefix}>
    <!-- Tab Headers -->
    <div class="flex border-b border-gray-200 mb-4">
        {
            languages.map((lang, index) => (
                <button
                    type="button"
                    class={`lang-tab px-4 py-2 text-sm font-medium flex items-center gap-2 border-b-2 transition-colors ${
                        index === 0
                            ? "border-primary-500 text-primary-600"
                            : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300"
                    }`}
                    data-lang={lang.code}
                    data-prefix={prefix}
                >
                    <span class="text-lg">{lang.flag}</span>
                    <span class="hidden sm:inline">{lang.name}</span>
                </button>
            ))
        }
    </div>

    <!-- Tab Contents -->
    {
        languages.map((lang, langIndex) => (
            <div
                class={`lang-tab-content space-y-4 ${langIndex === 0 ? "" : "hidden"}`}
                data-lang={lang.code}
                data-prefix={prefix}
            >
                {fields.map((field) => (
                    <div>
                        <label
                            for={`${prefix}_${getFieldName(field.name, lang.code)}`}
                            class="block text-sm font-medium text-gray-700 mb-1"
                        >
                            {field.label}
                            <span class="text-gray-400 ml-1">
                                ({lang.name})
                            </span>
                            {field.required && lang.code === "es" && (
                                <span class="text-red-500 ml-1">*</span>
                            )}
                        </label>

                        {field.type === "textarea" ? (
                            <textarea
                                name={getFieldName(field.name, lang.code)}
                                id={`${prefix}_${getFieldName(field.name, lang.code)}`}
                                rows={field.rows || 3}
                                required={field.required && lang.code === "es"}
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-primary-500 focus:border-primary-500"
                                placeholder={
                                    field.placeholder
                                        ? `${field.placeholder} (${lang.name})`
                                        : ""
                                }
                            >
                                {getValue(field.name, lang.code)}
                            </textarea>
                        ) : (
                            <input
                                type="text"
                                name={getFieldName(field.name, lang.code)}
                                id={`${prefix}_${getFieldName(field.name, lang.code)}`}
                                value={getValue(field.name, lang.code)}
                                required={field.required && lang.code === "es"}
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-primary-500 focus:border-primary-500"
                                placeholder={
                                    field.placeholder
                                        ? `${field.placeholder} (${lang.name})`
                                        : ""
                                }
                            />
                        )}
                    </div>
                ))}

                {lang.code !== "es" && (
                    <p class="text-xs text-gray-400 italic">
                        Los campos en otros idiomas son opcionales
                    </p>
                )}
            </div>
        ))
    }
</div>

<style>
    .lang-tabs-container {
        background: #fafafa;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 1rem;
    }
</style>

<script is:inline>
    // Initialize language tabs functionality
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".lang-tab").forEach((tab) => {
            tab.addEventListener("click", function () {
                const lang = this.dataset.lang;
                const prefix = this.dataset.prefix;
                const container = this.closest(".lang-tabs-container");

                // Update tab styles
                container.querySelectorAll(".lang-tab").forEach((t) => {
                    t.classList.remove(
                        "border-primary-500",
                        "text-primary-600",
                    );
                    t.classList.add("border-transparent", "text-gray-500");
                });
                this.classList.remove("border-transparent", "text-gray-500");
                this.classList.add("border-primary-500", "text-primary-600");

                // Show/hide content
                container
                    .querySelectorAll(".lang-tab-content")
                    .forEach((content) => {
                        if (content.dataset.lang === lang) {
                            content.classList.remove("hidden");
                        } else {
                            content.classList.add("hidden");
                        }
                    });
            });
        });
    });
</script>
